# zrokui — Environment Variables
# cp .env.example .env

# ── Domain ─────────────────────────────────────────────────────
BASE_DOMAIN=yourdomain.com

# ── zrok ───────────────────────────────────────────────────────
# openssl rand -hex 32
ZROK_ADMIN_TOKEN=replace_with_random_hex
ZITI_ADMIN_PASSWORD=replace_with_strong_password

# ── Backend ────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=replace_with_random_hex
REDIS_PASSWORD=replace_with_redis_password

# Admin email (this user gets isAdmin=true)
ADMIN_EMAIL=admin@yourdomain.com

# Set true to require invite for new signups
INVITES_ONLY=false

# ── Email (for invites) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_app_password
